# Server
PORT=3000

# Certificate monitor
MCM_TEAM_NUMBER=your_team_number
CERT_BASE_URL=https://www.comap-math.org/mcm/2026Certs
CHECK_INTERVAL_MINUTES=15
DOWNLOAD_FILENAME=certificate.pdf

# SMTP email settings. Use an app password / authorization code, not your login password.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
